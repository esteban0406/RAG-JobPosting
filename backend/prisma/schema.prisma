generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id          String         @id @default(cuid())
  sourceId    String
  source      String
  title       String
  company     String
  location    String?
  description String
  url         String
  jobType     String?
  minSalary   Int?
  maxSalary   Int?
  contentHash      String
  summary          String?
  salary           String?
  responsibilities String[]       @default([])
  requirements     String[]       @default([])
  benefits         String[]       @default([])
  skills           String[]       @default([])
  logo             String?
  fetchedAt        DateTime       @default(now())
  createdAt   DateTime       @default(now())
  chunks      JobChunk[]
  favoritedBy UserFavorite[]

  @@unique([source, sourceId])
  @@index([source, contentHash])
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String
  name            String
  skills          String[]
  preferredFields String[]
  location        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  favorites       UserFavorite[]
  resume          Resume?
}

model Resume {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filePath       String
  rawText        String
  parsedData     Json
  embeddingModel String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserFavorite {
  userId  String
  jobId   String
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@id([userId, jobId])
}

model JobChunk {
  id               String   @id @default(cuid())
  jobId            String
  chunkType        String   @default("full")
  chunkText        String
  embeddingModel   String
  embeddingVersion Int      @default(1)
  createdAt        DateTime @default(now())
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}
