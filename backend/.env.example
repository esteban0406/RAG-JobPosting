# Application
NODE_ENV=development
PORT=3000

# Database — direct PostgreSQL connection with pgvector extension installed
DATABASE_URL=postgresql://user:password@localhost:5432/jobpostings

GEMINI_API_KEY=

LOCAL_EMBEDDING_URL=http://localhost:8000

LLM_MODEL=gemini-3.1-flash-lite-preview

JWT_SECRET=your-secret-at-least-16-chars
ADMIN_API_KEY=your-admin-key
JWT_EXPIRES_IN=24h

# Ingestion cron schedule (default: every 6 hours)
INGESTION_CRON=0 */6 * * *

ADZUNA_API_KEY=your-adzuna-api-key
ADZUNA_APP_ID=your-adzuna-app-id

WEBNINJA_API_KEY=your-webninja-api-key

CAREERJET_API_KEY=your-careerjet-api-key