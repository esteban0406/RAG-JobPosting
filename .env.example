# Application
NODE_ENV=development
PORT=3000

# Database — direct PostgreSQL connection with pgvector extension installed
DATABASE_URL=postgresql://user:password@localhost:5432/jobpostings

# Google Gemini API (free tier)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# LLM model (default: gemini-2.0-flash)
LLM_MODEL=gemini-2.0-flash

# Ingestion cron schedule (default: every 6 hours)
INGESTION_CRON=0 */6 * * *

# --- Phase 3 (Redis + Auth) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# JWT_SECRET=
# ADMIN_API_KEY=
